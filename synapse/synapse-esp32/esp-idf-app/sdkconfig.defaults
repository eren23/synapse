# Enable experimental features (required for PSRAM 200MHz)
CONFIG_IDF_EXPERIMENTAL_FEATURES=y

# Flash size (32MB NOR flash on Waveshare ESP32-P4)
CONFIG_ESPTOOLPY_FLASHSIZE_32MB=y

# PSRAM (32MB on Waveshare ESP32-P4)
CONFIG_SPIRAM=y
# Must explicitly unset 20M for the choice to pick 200M
CONFIG_SPIRAM_SPEED_20M=n
CONFIG_SPIRAM_SPEED_200M=y

# Custom partition table (16MB factory for embedded model)
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# WiFi via esp_hosted + esp_wifi_remote (C6 companion over SDIO)
# Do NOT set CONFIG_ESP_HOST_WIFI_ENABLED -- that's for chips with native WiFi
CONFIG_ESP_WIFI_REMOTE_LIBRARY_HOSTED=y
CONFIG_SLAVE_IDF_TARGET_ESP32C6=y

# HTTP server tuning
CONFIG_HTTPD_MAX_REQ_HDR_LEN=1024
CONFIG_HTTPD_MAX_URI_LEN=512

# Compiler: optimize for performance instead of debug (-O2 vs -Og)
CONFIG_COMPILER_OPTIMIZATION_PERF=y

# Increase main task stack (encoder with -O2 inlining needs more)
CONFIG_ESP_MAIN_TASK_STACK_SIZE=16384

# Larger TCP buffers for image upload (602KB binary)
CONFIG_LWIP_TCP_SND_BUF_DEFAULT=32768
CONFIG_LWIP_TCP_WND_DEFAULT=32768

# WiFi credentials (set via menuconfig or override here)
CONFIG_LEWM_WIFI_SSID="FiberHGW_ZY1B56"
CONFIG_LEWM_WIFI_PASS="YvtHq3vPAX9U"
